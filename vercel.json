{
  "buildCommand": "cd apps/web && node ../../node_modules/vite/bin/vite.js build",
  "outputDirectory": "apps/web/dist",
  "framework": null,
  "installCommand": "npm install --include=dev --workspaces --include-workspace-root",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 512,
      "maxDuration": 30
    }
  }
}
